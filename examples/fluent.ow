type Amount = Int
type Balance = Int
type Name = String

struct Wallet {
  Balance,
  Name,
}

fn addBalance(Wallet, Amount) -> Wallet {
  Wallet { Balance(wallet.balance.value + amount.value), wallet.name }
}

fn create(Name) -> Wallet {
  Wallet { Balance(0), name }
}

fn getBalance(Wallet) -> Balance {
  wallet.balance
}

fn main() {
  create(Name("Alice")).addBalance(Amount(100)).addBalance(Amount(50)).getBalance().print()
}
